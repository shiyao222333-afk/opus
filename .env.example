# OpusMagnum 环境变量模板
# 复制此文件为 .env 并填写实际值

# --- 项目间通信 ---
# API 认证密钥（各项目统一使用此值）
OPUS_API_KEY=opus-magnum-local

# --- 各项目地址配置 ---
# 格式：PROJECT_PORT、PROJECT_URL
ATHANOR_PORT=8501
ATHANOR_URL=http://localhost:8501

ALEMBIC_PORT=8502
ALEMBIC_URL=http://localhost:8502

CRUCIBLE_PORT=8503
CRUCIBLE_URL=http://localhost:8503

ELIXIR_PORT=8504
ELIXIR_URL=http://localhost:8504

OPUSMAGNUM_PORT=8500
OPUSMAGNUM_URL=http://localhost:8500

# --- GitHub 配置（用于读取 Issues/状态）---
# GitHub Personal Access Token（只需要 read 权限）
GITHUB_TOKEN=

# GitHub 用户名
GITHUB_USERNAME=shiyao222333-afk

# 各项目仓库名
ATHANOR_REPO=shiyao222333-afk/athanor
ALEMBIC_REPO=shiyao222333-afk/alembic
CRUCIBLE_REPO=shiyao222333-afk/crucible
OPUSMAGNUM_REPO=shiyao222333-afk/opus-magnum

# --- 通知配置（可选，初期不用）---
# 微信通知 Webhook（企业微信/Server酱）
WECHAT_WEBHOOK_URL=

# --- 日志 ---
LOG_LEVEL=INFO
